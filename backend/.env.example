# Controlla backend — copy to .env for local dev. Every variable has a dev default in src/config.ts.

PORT=4000
NODE_ENV=development
# Ports match backend/docker-compose.yml (remapped: host 27018/6381).
MONGO_URL=mongodb://localhost:27018/controlla
REDIS_URL=redis://localhost:6381
# Refused in production if left at the default.
JWT_SECRET=dev-secret-change-me
# QR base URL — must be the tunnel URL (cloudflared/ngrok) so phones on cellular can reach it.
# joinUrl = {PUBLIC_WEB_URL}/play/{code}?t={joinToken}
PUBLIC_WEB_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
SESSION_TTL_MS=86400000
GRACE_PERIOD_MS=120000
JOIN_TOKEN_TTL_MS=900000
JOIN_TOKEN_ROTATE_MS=60000
RATE_LIMIT_JOIN_PER_MIN=10
WS_INPUT_RATE_PER_SEC=20
WS_INPUT_BURST=40
SWEEP_INTERVAL_MS=5000
# Directory scanned at boot for provider game packages (docs/GAME_PROVIDER_GUIDE.md).
GAMES_DIR=games
LOG_LEVEL=info

# Admin panel login — set real values in .env (gitignored)
ADMIN_EMAIL=admin@controlla.com
ADMIN_PASSWORD=change-me-admin!
